# Trigger.dev
TRIGGER_SECRET_KEY=tr_prod_xxx

# Vercel Sandbox
VERCEL_TOKEN=xxx
VERCEL_TEAM_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx

# Agent — each supports API key or OAuth
DEFAULT_AGENT=claude
# Claude: set one of these
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_CODE_OAUTH_TOKEN=
# Codex: set one of these
OPENAI_API_KEY=sk-xxx
CODEX_AUTH_JSON_B64=          # base64 < ~/.codex/auth.json | tr -d '\n'

# Slack
SLACK_SIGNING_SECRET=xxx
SLACK_BOT_TOKEN=xoxb-xxx

# GitHub App
GITHUB_APP_ID=123456
# Use B64 (recommended) — avoids multiline PEM issues:
#   base64 < your-app.private-key.pem | tr -d '\n'
GITHUB_APP_PRIVATE_KEY_B64=
# Or raw PEM (for local dev only):
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Optional
SENTRY_WEBHOOK_SECRET=xxx
APP_BASE_URL=https://your-app.example.com
REQUIRE_SENTRY_APPROVAL=false
