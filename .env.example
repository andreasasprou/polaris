# ── Database ──
DATABASE_URL=postgresql://polaris:polaris@localhost:5432/polaris
ENCRYPTION_KEY=           # openssl rand -hex 32  (64 hex chars)

# ── Authentication ──
BETTER_AUTH_SECRET=       # openssl rand -base64 32
GITHUB_CLIENT_ID=         # GitHub OAuth app (user login)
GITHUB_CLIENT_SECRET=     # GitHub OAuth app (user login)

# ── GitHub App ──
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_B64=   # base64 < your-app.private-key.pem | tr -d '\n'
GITHUB_APP_WEBHOOK_SECRET=    # random string for webhook signature verification
# GITHUB_APP_SLUG=polaris-agent  # optional, defaults to polaris-agent

# ── Trigger.dev ──
TRIGGER_SECRET_KEY=tr_dev_xxx

# ── Vercel Sandbox ──
VERCEL_TOKEN=xxx
VERCEL_TEAM_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx

# ── Agent credentials (set at least one pair) ──
DEFAULT_AGENT=claude
# Claude: set one of these
ANTHROPIC_API_KEY=sk-ant-xxx
# CLAUDE_CODE_OAUTH_TOKEN=
# Codex: set one of these
# OPENAI_API_KEY=sk-xxx
# CODEX_AUTH_JSON_B64=      # base64 < ~/.codex/auth.json | tr -d '\n'

# ── Optional: Slack ──
# SLACK_SIGNING_SECRET=xxx
# SLACK_BOT_TOKEN=xoxb-xxx

# ── Optional: Sentry ──
# SENTRY_WEBHOOK_SECRET=xxx

# ── Optional: App URL (defaults to http://localhost:3000) ──
# APP_BASE_URL=https://your-app.example.com
