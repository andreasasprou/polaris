{
  "name": "polaris",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "portless polaris.local.plrs next dev --turbopack",
    "dev:raw": "next dev --turbopack",
    "build": "node scripts/vercel-build.mjs",
    "build:next": "next build",
    "start": "next start",
    "backfill:oauth-tokens": "tsx scripts/backfill-oauth-token-encryption.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "check:architecture": "bash scripts/check-architecture.sh",
    "check:deps": "bash scripts/check-deps.sh",
    "check:reference-docs": "tsx scripts/check-reference-versions.ts",
    "boot:worktree": "bash scripts/boot-worktree.sh",
    "teardown:worktree": "bash scripts/teardown-worktree.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@sandbox-agent/persist-postgres": "0.3.2",
    "@vercel/sandbox": "^1.8.0",
    "acp-http-client": "0.3.2",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "diff": "^8.0.3",
    "drizzle-orm": "^0.45.1",
    "evlog": "^2.8.0",
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.577.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "minimatch": "^10.2.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sandbox-agent": "0.3.2",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/eslintrc": "^3",
    "@openai/codex-sdk": "^0.116.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vercel/config": "^0.0.40",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import-x": "^4.16.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
